{
  "name": "electron-workspace",
  "private": true,
  "version": "0.1.0",
  "main": ".vite/build/index.js",
  "scripts": {
    "start": "electron-forge start",
    "dev": "electron-forge start",
    "lint": "eslint . --ignore-pattern .vite --ignore-pattern out --ignore-pattern dist --ignore-pattern playwright-report --ignore-pattern test-results",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:app": "electron-forge package",
    "e2e": "npm run build:app && playwright test",
    "build": "npm run build:app",
    "make": "electron-forge make",
    "verify": "npm run lint && npm run test && npm run e2e && npm run build"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-vite": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^38.0.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "jsdom": "^27.0.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
}
