set shell := ["bash", "-uc"]

default:
  @just --list

install:
  npm install

dev:
  npm run dev

lint:
  npm run lint

test:
  npm test

e2e:
  npm run e2e

build:
  npm run build

package:
  npm run build:app

make:
  npm run make

verify:
  npm run verify

verify-no-e2e:
  npm run lint && npm test && npm run build
